# ════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ════════════════════════════════════════════════════════════════

# ─── Site password (what guests type at /password) ───
SITE_PASSWORD=antigua2027

# ─── Admin dashboard password (change this, something only you know) ───
ADMIN_PASSWORD=change-me-to-something-strong

# ─── JWT secret for signing cookies (generate with: openssl rand -base64 32) ───
AUTH_SECRET=generate-a-long-random-string-here-at-least-32-chars

# ─── Airtable ───
# 1. Create a base at airtable.com (see README for schema)
# 2. Create a personal access token at airtable.com/create/tokens
#    Scopes: data.records:read, data.records:write
#    Access: grant it access to your base
AIRTABLE_API_KEY=patXXXXXXXXXXXX.XXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_NAME=Guests

# ─── Resend (email) ───
# 1. Sign up at resend.com
# 2. Add + verify elexusandxandor.com as a domain
# 3. Create an API key
RESEND_API_KEY=re_XXXXXXXXXXXX
RESEND_FROM_EMAIL=hello@elexusandxandor.com
RESEND_FROM_NAME=Elexus & Xandor

# ─── Site URL (used for email links) ───
NEXT_PUBLIC_SITE_URL=https://elexusandxandor.com
